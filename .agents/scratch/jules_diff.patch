@@ -0,0 +1,47 @@
+const fs = require('fs');
+
+const path = 'components/shared/BadgeVisual.tsx';
+let code = fs.readFileSync(path, 'utf8');
+
+// There are remaining usages of themeColors.accent instead of the current rarity. Let's fix that.
+// First, find and define `const currentTheme = themeColors[rarity] || themeColors['Common']` at the top of the component logic.
+
+code = code.replace(
+  "export const BadgeVisual: React.FC<BadgeVisualProps> = ({",
+  "export const BadgeVisual: React.FC<BadgeVisualProps> = ({\n"
+);
+
+// We need to inject currentTheme right after props destructuring.
+const injectionPoint = "}) => {";
+const injectedCode = `}) => {
+  const currentTheme = themeColors[rarity] || themeColors['Common'];`;
+
+code = code.replace(injectionPoint, injectedCode);
+
+// Replace usages
+code = code.replace(/themeColors\.accent/g, "currentTheme.accent");
+code = code.replace(/themeColors\.glow/g, "currentTheme.glow");
+code = code.replace(/themeColors\.stops/g, "currentTheme.stops");
+code = code.replace(/themeColors\.bgAccent/g, "currentTheme.bgAccent");
+code = code.replace(/themeColors\.gradientId/g, "currentTheme.gradientId");
+
+// Update renderBadgeIcon back to use currentTheme.stitch etc
+code = code.replace(
+  "const stitchStroke = isEarned ? (themeColors[rarity] || themeColors['Common']).stitch : '#475569';",
+  "const stitchStroke = isEarned ? currentTheme.stitch : '#475569';"
+);
+code = code.replace(
+  "const fillFabric = isEarned ? (themeColors[rarity] || themeColors['Common']).fabric : '#1e293b';",
+  "const fillFabric = isEarned ? currentTheme.fabric : '#1e293b';"
+);
+code = code.replace(
+  "const bgFabricColor = isEarned ? (themeColors[rarity] || themeColors['Common']).bgFabric : '#0f172a';",
+  "const bgFabricColor = isEarned ? currentTheme.bgFabric : '#0f172a';"
+);
+code = code.replace(
+  "style={{ borderColor: (themeColors[rarity] || themeColors['Common']).stitch }}",
+  "style={{ borderColor: currentTheme.stitch }}"
+);
+
+
+fs.writeFileSync(path, code);

{
  "name": "Apex Driving Academy Design System",
  "version": "1.0.0",
  "tokens": {
    "colors": {
      "base": {
        "navy-950": "#0A0E1A",
        "navy-900": "#0F1422",
        "navy-800": "#13192B",
        "navy-700": "#1E2A4A"
      },
      "brand": {
        "primary": "#2563EB",
        "primary-light": "#4D7CFF",
        "primary-dark": "#1D4ED8",
        "accent": "#F59E0B",
        "accent-light": "#F7CA6E",
        "accent-dark": "#D97706"
      },
      "feedback": {
        "success": "#10B981",
        "warning": "#F59E0B",
        "error": "#EF4444"
      }
    },
    "typography": {
      "fonts": {
        "display": "'Outfit', sans-serif",
        "body": "'Inter', sans-serif"
      },
      "scale": {
        "step-1": { "fontSize": "12px", "lineHeight": "16px", "letterSpacing": "0.02em" },
        "step-2": { "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "0.01em" },
        "step-3": { "fontSize": "16px", "lineHeight": "24px", "letterSpacing": "0" },
        "step-4": { "fontSize": "18px", "lineHeight": "28px", "letterSpacing": "-0.01em" },
        "step-5": { "fontSize": "20px", "lineHeight": "28px", "letterSpacing": "-0.01em" },
        "step-6": { "fontSize": "24px", "lineHeight": "32px", "letterSpacing": "-0.02em" },
        "step-7": { "fontSize": "30px", "lineHeight": "36px", "letterSpacing": "-0.02em" },
        "step-8": { "fontSize": "36px", "lineHeight": "40px", "letterSpacing": "-0.03em" },
        "step-9": { "fontSize": "48px", "lineHeight": "48px", "letterSpacing": "-0.04em" }
      }
    },
    "spacing": {
      "base": "4px",
      "tokens": {
        "space-tight": "8px",
        "space-inline": "16px",
        "space-gap": "24px",
        "space-card": "32px",
        "space-section": "120px"
      }
    },
    "animation": {
      "easings": {
        "ease-spring": "cubic-bezier(0.68, -0.6, 0.32, 1.6)",
        "ease-smooth": "cubic-bezier(0.4, 0, 0.2, 1)",
        "ease-snap": "cubic-bezier(0.77, 0, 0.175, 1)"
      }
    }
  }
}
